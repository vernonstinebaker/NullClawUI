# ============================================================
# NullClawUI — .gitignore
# Xcode / Swift / macOS
# ============================================================

# ── Xcode ────────────────────────────────────────────────────
*.xcuserstate
*.xcscmblueprint
*.xcbaseline
xcuserdata/
*.xccheckout
*.moved-aside
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# ── Swift Package Manager ────────────────────────────────────
.build/
.swiftpm/configuration/
.swiftpm/xcode/
SourcePackages/
Packages/

# Note: Package.resolved is intentionally committed so that
# Swift Package dependency versions are reproducible across
# machines and CI.
# Package.resolved   ← keep this commented out

# ── CocoaPods (not used, but just in case) ────────────────────
Pods/
*.xcworkspace

# ── Fastlane ────────────────────────────────────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ── Simulators / Instruments ─────────────────────────────────
*.instrumentstrace
timeline.xctimeline

# ── Build outputs ────────────────────────────────────────────
build/
*.o
*.a
/test_self_spawn
/main

# ── Secrets / Credentials ────────────────────────────────────
# Never commit tokens, certs, or provisioning profiles.
*.p8
*.p12
*.mobileprovision
*.cer
Secrets.swift
Secrets.xcconfig
secrets.json

# ── Editor / IDE ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Local agent context ──────────────────────────────────────
# Machine-specific ops notes and signing config. Never commit.
AGENTS.local.md
*.local.xcconfig

# ── SwiftLint / SwiftFormat ──────────────────────────────────
.swiftlintcache
.swiftformatcache

# ── Misc ─────────────────────────────────────────────────────
*.log
